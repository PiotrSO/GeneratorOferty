{
  "name": "system-serwis-generator",
  "version": "1.1.0",
  "description": "Profesjonalny generator ofert i kalkulator kosztów dla branży utrzymania czystości.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win --publish never",
    "pack": "electron-builder build --dir"
  },
  "keywords": [
    "electron",
    "generator",
    "oferty",
    "cleaning-service",
    "kalkulator"
  ],
  "author": "Piotr S.",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.systemserwis.generator",
    "productName": "System Serwis - Generator Ofert",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    }
  }
}
